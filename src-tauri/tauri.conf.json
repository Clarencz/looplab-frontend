{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LoopLab",
  "version": "1.0.0",
  "identifier": "com.looplab.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LoopLab - Learn to Code by Building Real Projects",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "userAgent": "LoopLabDesktop"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/looplab-ai-pipeline"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "LoopLab",
    "copyright": "Copyright © 2026 LoopLab. All rights reserved.",
    "category": "DeveloperTool",
    "shortDescription": "Learn to code by building real projects",
    "longDescription": "LoopLab is an AI-powered learning platform that helps you master programming through hands-on projects in data science, algorithms, finance, and more."
  }
}